{
  "name": "marketing-azul",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "seed": "pnpm --filter @marketing-azul/backend run db:seed"
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "@nestjs/core"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
