# ===========================================
# Marketing Azul - Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha os valores

# -------------------------------------------
# Application
# -------------------------------------------
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketing_azul?schema=public"
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=marketing_azul

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# OpenAI (para IA)
# -------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# -------------------------------------------
# Email (SendGrid - opcional)
# -------------------------------------------
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@empresaazul.com

# -------------------------------------------
# CORS
# -------------------------------------------
CORS_ORIGIN=http://localhost:5173

# -------------------------------------------
# File Upload (opcional)
# -------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads