# ===========================================
# Marketing Azul - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para apps/backend/.env (o backend lê o .env da própria pasta).

# Aplicação
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Banco de dados: SQLite (arquivo local, nada para instalar ou subir).
# O arquivo é criado automaticamente no primeiro boot dentro de apps/backend.
DATABASE_PATH=marketing_azul.sqlite

# Autenticação JWT (troque por chaves próprias em produção)
JWT_SECRET=chave-secreta-jwt-com-no-minimo-32-caracteres-troque
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=chave-secreta-refresh-com-no-minimo-32-caracteres-troque
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (opcional — necessário apenas para as funcionalidades de IA)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
