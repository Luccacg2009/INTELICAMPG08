# Meeting AI - Configuração via variáveis de ambiente
# Copie para .env e ajuste conforme necessário

# Áudio
WHISPER_MODEL=base          # tiny, base, small, medium, large-v3
WHISPER_DEVICE=auto         # auto, cpu, cuda
WHISPER_COMPUTE_TYPE=int8   # int8, int16, float16, float32

# LLM (escolha um provedor)
LLM_PROVIDER=ollama         # ollama, openai, groq
LLM_MODEL=llama3.1:8b       # modelo do provedor escolhido

# Ollama (local)
OLLAMA_HOST=http://localhost:11434

# OpenAI (cloud)
OPENAI_API_KEY=sua-chave-aqui

# Groq (cloud, rápido)
GROQ_API_KEY=sua-chave-aqui

# Saída
OUTPUT_DIR=./output