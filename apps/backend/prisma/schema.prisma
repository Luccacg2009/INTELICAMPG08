generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  WORKER
}

enum UserVertical {
  MARKETING
  PRODUCT
  SALES
  ENGINEERING
  DESIGN
  OPERATIONS
  FINANCE
  HR
  LEGAL
  OTHER
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  IN_DEVELOPMENT
  LAUNCHED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String
  name          String
  role          UserRole     @default(WORKER)
  vertical      UserVertical @default(MARKETING)
  avatarUrl     String?
  isActive      Boolean      @default(true)
  lastLoginAt   DateTime?
  mustChangePassword Boolean @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  projects          Project[]          @relation("ProjectAuthor")
  evaluations       ProjectEvaluation[] @relation("ProjectEvaluator")
  aiConversations   AIConversation[]   @relation("ConversationUser")
  aiMessages        AIMessage[]        @relation("MessageUser")
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Project {
  id              String        @id @default(cuid())
  title           String
  description     String
  centralIdea     String        @map("central_idea")
  targetAudience  String        @map("target_audience")
  vertical        UserVertical
  authorId        String
  author          User          @relation("ProjectAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reason          String?
  launchLocation  String?       @map("launch_location")
  status          ProjectStatus @default(DRAFT)
  priority        ProjectPriority @default(MEDIUM)
  
  aiSummary       String?       @map("ai_summary")
  aiStrengths     String?       @map("ai_strengths")
  aiWeaknesses    String?       @map("ai_weaknesses")
  aiDevelopment   String?       @map("ai_development")
  pdfUrl          String?       @map("pdf_url")

  evaluations     ProjectEvaluation[]
  aiConversation  AIConversation?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("projects")
}

model ProjectEvaluation {
  id                String        @id @default(cuid())
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluatorId       String
  evaluator         User          @relation("ProjectEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  status            ProjectStatus
  strengths         String?
  weaknesses        String?
  suggestions       String?
  recommendation    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([projectId, evaluatorId])
  @@map("project_evaluations")
}

model AIConversation {
  id          String   @id @default(cuid())
  projectId   String?  @unique
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    AIMessage[]

  @@map("ai_conversations")
}

model AIMessage {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation("MessageUser", fields: [userId], references: [id], onDelete: Cascade)
  role            String   // 'user' | 'assistant'
  content         String
  metadata        Json?
  createdAt       DateTime @default(now())

  @@map("ai_messages")
}